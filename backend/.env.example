# ---- Neon Postgres ----
# Neon dashboard -> your project -> Connection string (choose "Pooled connection").
# It looks like: postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ---- Server ----
PORT=3000

# ---- Cloudinary (image uploads) ----
# Cloudinary dashboard -> Product Environment Credentials.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: a folder to keep uploads tidy, e.g. cars24-social-calendar
CLOUDINARY_FOLDER=cars24-social-calendar
